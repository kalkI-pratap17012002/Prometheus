# =============================================================================
# ML-WAF environment — copy to .env and fill in real values before bringing
# the stack up. Never commit the populated .env file.
# =============================================================================

# --- Postgres ----------------------------------------------------------------
POSTGRES_DB=waf
POSTGRES_USER=waf
POSTGRES_PASSWORD=change-me-postgres

# --- Redis -------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_STREAM=waf:requests

# --- InfluxDB ----------------------------------------------------------------
INFLUX_USERNAME=waf
INFLUX_PASSWORD=change-me-influx
INFLUX_ORG=ml-waf
INFLUX_BUCKET=waf_metrics
INFLUX_TOKEN=change-me-influx-token
INFLUX_RETENTION=4w

# --- Grafana -----------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana

# --- ML engine ---------------------------------------------------------------
WAF_LOG_THRESHOLD=0.4
WAF_BLOCK_THRESHOLD=0.8

# --- Threat Intelligence -----------------------------------------------------
# AbuseIPDB API key. Leave blank to skip that feed; the Emerging Threats
# blocklist still syncs because it requires no auth.
ABUSEIPDB_API_KEY=
THREAT_INTEL_INTERVAL_S=21600
THREAT_INTEL_EXPIRY_H=24
